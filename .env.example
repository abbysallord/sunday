# ============================================================
# SUNDAY Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- LLM Providers (get free API keys) ---
# Groq: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google AI Studio: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# --- LLM Settings ---
# Primary provider: groq, google, ollama
SUNDAY_LLM_PRIMARY_PROVIDER=groq
SUNDAY_LLM_PRIMARY_MODEL=llama-3.3-70b-versatile
SUNDAY_LLM_FALLBACK_PROVIDER=google
SUNDAY_LLM_FALLBACK_MODEL=gemini-2.0-flash
SUNDAY_LLM_OFFLINE_MODEL=qwen2.5:3b

# --- Voice Settings ---
SUNDAY_TTS_VOICE=en_US-amy-medium
SUNDAY_STT_MODEL=base.en
SUNDAY_VAD_THRESHOLD=0.5

# --- Server ---
SUNDAY_HOST=127.0.0.1
SUNDAY_PORT=8000
SUNDAY_LOG_LEVEL=info

# --- Database ---
SUNDAY_DB_PATH=data/sunday.db
SUNDAY_CHROMA_PATH=data/chroma
